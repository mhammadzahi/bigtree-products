# Nginx site for the Bigtree Products staff catalog.
# Install:
#   sudo cp deploy/bt_products /etc/nginx/sites-available/bt_products
#   sudo ln -s /etc/nginx/sites-available/bt_products /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx
#
# Then get SSL (certbot rewrites this file to add the 443 server + redirect):
#   sudo apt install -y certbot python3-certbot-nginx
#   sudo certbot --nginx -d staff.bigtree-group.com
#
# DNS: point an A record  staff.bigtree-group.com -> this server's IP first.
# After HTTPS is live, set SECURE_COOKIE=true in .env and restart the service.

server {
    listen 80;
    listen [::]:80;
    server_name staff.bigtree-group.com;

    # allow moderately large form posts / uploads if ever needed
    client_max_body_size 8m;

    # Reverse-proxy everything to the Go app on localhost.
    location / {
        proxy_pass         http://127.0.0.1:8080;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_read_timeout 60s;
    }

    # Optional: let nginx serve static assets directly (faster, less Go load).
    # Point this at the repo's static/ directory on your server:
    # location /static/ {
    #     alias /home/bigtree/bigtree-products/static/;
    #     expires 7d;
    #     access_log off;
    # }
}
