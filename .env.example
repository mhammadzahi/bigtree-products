# Copy to .env and adjust. All values have local-friendly defaults if unset.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=bigtree
# Or set a full DSN and it overrides the pieces above:
# DB_DSN=user:pass@tcp(127.0.0.1:3306)/bigtree?parseTime=true&charset=utf8mb4&loc=Local

LISTEN_ADDR=:8080
# Set to true when serving over HTTPS so the session cookie gets the Secure flag.
SECURE_COOKIE=false
